message Twist {
    seq:         u32,
    timestamp:   i64,
    linear_x:    f32,
    linear_y:    f32,
    angular_z:   f32,
}

message Odometry {
    seq:         u32,
    timestamp:   i64,
    x:           f32,
    y:           f32,
    theta:       f32,
    linear_vel:  f32,
    angular_vel: f32,
}

message BatteryStatus {
    seq:         u32,
    timestamp:   i64,
    voltage:     f32,
    current:     f32,
    percentage:  f32,
}
